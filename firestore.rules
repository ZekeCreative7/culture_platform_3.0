rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMaster() {
      return signedIn()
        && request.auth.token.email == 'rhokoo7@naver.com';
    }

    function isApproved() {
      return isMaster()
        || (signedIn()
          && exists(/databases/$(database)/documents/accessRequests/$(request.auth.uid))
          && get(/databases/$(database)/documents/accessRequests/$(request.auth.uid)).data.status == 'approved');
    }

    function approvedAccess() {
      return signedIn()
        && exists(/databases/$(database)/documents/accessRequests/$(request.auth.uid))
        && get(/databases/$(database)/documents/accessRequests/$(request.auth.uid)).data.status == 'approved';
    }

    function approvedOrgId() {
      return get(/databases/$(database)/documents/accessRequests/$(request.auth.uid)).data.organizationId;
    }

    function sameOrg(data) {
      return isMaster()
        || (approvedAccess()
          && data.organizationId is string
          && data.organizationId == approvedOrgId());
    }

    function sameOrgRead() {
      return sameOrg(resource.data);
    }

    function sameOrgWrite() {
      return sameOrg(request.resource.data);
    }

    function sameOrgUpdate() {
      return sameOrg(resource.data) && sameOrg(request.resource.data);
    }

    function surveyActive(data) {
      return data.status != 'closed'
        && data.deletedAt == null
        && (
          data.distributionActive == true
          || (data.keys().hasAny(['distribution'])
            && data.distribution.keys().hasAny(['active'])
            && data.distribution.active == true)
          || (!data.keys().hasAny(['distribution'])
            && !data.keys().hasAny(['distributionActive'])
            && data.status != 'closed')
        );
    }

    function linkedSurvey(responseData) {
      return get(/databases/$(database)/documents/surveys/$(responseData.surveyId));
    }

    function distributionIdMatchesSurvey(responseData, surveyData) {
      return responseData.distributionId == 'distribution-' + responseData.surveyId
        || (surveyData.keys().hasAny(['distribution'])
          && surveyData.distribution.keys().hasAny(['id'])
          && responseData.distributionId == surveyData.distribution.id);
    }

    function publicResponseCreateAllowed() {
      return request.resource.data.keys().hasAll([
          'surveyId',
          'distributionId',
          'sessionId',
          'organizationId',
          'phase',
          'cohort',
          'sourceType',
          'createdAt'
        ])
        && request.resource.data.keys().size() <= 80
        && request.resource.data.surveyId is string
        && exists(/databases/$(database)/documents/surveys/$(request.resource.data.surveyId))
        && surveyActive(linkedSurvey(request.resource.data).data)
        && request.resource.data.organizationId == linkedSurvey(request.resource.data).data.organizationId
        && request.resource.data.sessionId == linkedSurvey(request.resource.data).data.sessionId
        && request.resource.data.phase == linkedSurvey(request.resource.data).data.phase
        && distributionIdMatchesSurvey(request.resource.data, linkedSurvey(request.resource.data).data)
        && request.resource.data.sourceType == '링크 응답'
        && request.resource.data.createdAt == request.time;
    }

    match /accessRequests/{userId} {
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.status == 'pending';
      allow get: if signedIn() && (request.auth.uid == userId || isMaster());
      allow list, update, delete: if isMaster();
    }

    // Respondents use a public, anonymous survey link. They may read one
    // configured survey and create a response tied to that exact survey,
    // but cannot list surveys or read any submitted response.
    match /surveys/{surveyId} {
      allow get: if sameOrgRead() || surveyActive(resource.data);
      allow list: if sameOrgRead();
      allow create: if sameOrgWrite();
      allow update: if sameOrgUpdate();
      allow delete: if sameOrgRead();
    }

    match /responses/{responseId} {
      allow create: if publicResponseCreateAllowed() || (isApproved() && sameOrgWrite());
      allow read: if sameOrgRead();
      allow update: if sameOrgUpdate();
      allow delete: if sameOrgRead();
    }

    // A new member may trigger exactly one fixed approval notification to the
    // designated inbox. The email extension runs with server privileges.
    match /mail/{userId} {
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.requestUid == userId
        && request.resource.data.requesterEmail == request.auth.token.email
        && request.resource.data.to.size() == 1
        && request.resource.data.to[0] == 'zekedesign7@gmail.com'
        && request.resource.data.message.subject == '[Lina Culture Platform] 새로운 회원 승인 요청';
      allow read, update, delete: if isMaster();
    }

    // App state backup document is master-only
    match /appState/{document=**} {
      allow read, write: if isMaster();
    }

    // Secure operational collections to approved users
    match /sessions/{document=**} {
      allow read: if sameOrgRead();
      allow create: if sameOrgWrite();
      allow update: if sameOrgUpdate();
      allow delete: if sameOrgRead();
    }

    match /pulseResults/{document=**} {
      allow read: if sameOrgRead();
      allow create: if sameOrgWrite();
      allow update: if sameOrgUpdate();
      allow delete: if sameOrgRead();
    }

    match /pulseCommitments/{document=**} {
      allow read: if sameOrgRead();
      allow create: if sameOrgWrite();
      allow update: if sameOrgUpdate();
      allow delete: if sameOrgRead();
    }

    match /auditLogs/{logId} {
      allow read: if isMaster();
      allow create: if isApproved() && sameOrgWrite();
      allow update, delete: if isMaster();
    }

    match /QualSignal/{document=**} {
      allow read: if sameOrgRead();
      allow create: if sameOrgWrite();
      allow update: if sameOrgUpdate();
      allow delete: if sameOrgRead();
    }

    // Fallback for other collections (except accessRequests, mail, appState, responses, surveys, sessions, pulseResults, pulseCommitments, auditLogs, QualSignal)
    match /{collectionName}/{document=**} {
      allow read: if collectionName != 'accessRequests'
        && collectionName != 'mail'
        && collectionName != 'appState'
        && collectionName != 'responses'
        && collectionName != 'surveys'
        && collectionName != 'sessions'
        && collectionName != 'pulseResults'
        && collectionName != 'pulseCommitments'
        && collectionName != 'auditLogs'
        && collectionName != 'QualSignal'
        && isApproved()
        && sameOrgRead();
      allow create: if collectionName != 'accessRequests'
        && collectionName != 'mail'
        && collectionName != 'appState'
        && collectionName != 'responses'
        && collectionName != 'surveys'
        && collectionName != 'sessions'
        && collectionName != 'pulseResults'
        && collectionName != 'pulseCommitments'
        && collectionName != 'auditLogs'
        && collectionName != 'QualSignal'
        && isApproved()
        && sameOrgWrite();
      allow update: if collectionName != 'accessRequests'
        && collectionName != 'mail'
        && collectionName != 'appState'
        && collectionName != 'responses'
        && collectionName != 'surveys'
        && collectionName != 'sessions'
        && collectionName != 'pulseResults'
        && collectionName != 'pulseCommitments'
        && collectionName != 'auditLogs'
        && collectionName != 'QualSignal'
        && isApproved()
        && sameOrgUpdate();
      allow delete: if collectionName != 'accessRequests'
        && collectionName != 'mail'
        && collectionName != 'appState'
        && collectionName != 'responses'
        && collectionName != 'surveys'
        && collectionName != 'sessions'
        && collectionName != 'pulseResults'
        && collectionName != 'pulseCommitments'
        && collectionName != 'auditLogs'
        && collectionName != 'QualSignal'
        && isApproved()
        && sameOrgRead();
    }
  }
}
